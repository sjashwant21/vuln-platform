# ====================================================================
# VulnAssess Platform - .gitignore
# ====================================================================

# ── Environment & Secrets ───────────────────────────────────────────
.env
.env.local
.env.*.local
# (Note: .env.example should remain tracked)

# ── Certificates & Private Keys ─────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
*.der
*.cer
nginx/ssl/

# ── Python / Backend ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/

# ── Node / TypeScript / Frontend ────────────────────────────────────
node_modules/
.npm/
.next/
dist/
build/
.cache/

# ── Runtime Artifacts & Databases ───────────────────────────────────
*.log
*.db
*.sqlite3
celerybeat-schedule
celerybeat.pid

# ── Tool Caches & Testing ───────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ── IDEs & Editors ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ──────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Database Migrations (Alembic) ───────────────────────────────────
# Ensure migration versions are explicitly NOT ignored
!backend/alembic/versions/
!alembic/versions/
